# ── Required ─────────────────────────────────────────────────
# Network and DAO targeting. `pnpm fetch-dao` reads these to
# resolve your DAO's auction/governor/treasury addresses.
NEXT_PUBLIC_NETWORK_TYPE="mainnet"
NEXT_PUBLIC_CHAIN_ID="8453"
NEXT_PUBLIC_DAO_TOKEN_ADDRESS=""

# Required for the wallet Connect button. Free at https://cloud.reown.com.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=""

# ── Recommended ──────────────────────────────────────────────
# Speeds up RPC reads. Without it, public Base/mainnet RPCs are
# slow and ENS resolution on /members is skipped.
NEXT_PUBLIC_ALCHEMY_API_KEY=""

# Pinata scoped-key JWT — required for media uploads (Coins, future
# proposal/propdate attachments). Generate at https://app.pinata.cloud
# → API Keys → Scoped Key with pinFileToIPFS + pinJSONToIPFS enabled.
PINATA_API_KEY=""

# Optional Pinata public gateway override. Defaults to nouns-builder.mypinata.cloud.
# NEXT_PUBLIC_PINATA_GATEWAY=""

# Optional Etherscan API key (server-only — do NOT prefix with NEXT_PUBLIC_).
# Enables full transaction decoding on proposal pages: /api/decode fetches the
# target contract's verified ABI from Etherscan's v2 multichain endpoint (one
# key covers every chain via the chainid param). Without it, decoding still
# works but is heavily rate-limited; unknown txs fall back to a raw calldata
# card. Free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=""

# ── SEO / sitemap ─────────────────────────────────────────────
# Set to your deployed URL (no trailing slash) so sitemap.xml and
# robots.txt point to the correct domain.
# NEXT_PUBLIC_SITE_URL="https://yoursite.com"
