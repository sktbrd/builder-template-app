# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated config files (resolved on-chain by `pnpm fetch-dao`)
/src/config/dao.json
/src/config/dao.ts

# generated icon
/public/icon.png
.env*.local

# claude code agent worktrees (multi-GB local clones)
.claude/worktrees/

# session-local running notes
implementation-notes.md
